                { text: "인기 있는 것도 실력이라며 신경 쓰지 않는다", type: "d" }
            ]
        },
        {
            q: "19. 파이널 생방송 전날 밤, 혼자 있을 때?",
            options: [
                { text: "떨어지면 어쩌나 하는 생각에 눈물이 난다", type: "a" },
                { text: "마지막 무대 동선을 머릿속으로 무한 반복한다", type: "b" },
                { text: "탈출하고 싶다는 생각과 불안함이 교차한다", type: "c" },
                { text: "졸리니까 일단 자고 내일 생각하기로 한다", type: "d" }
            ]
        }
    ];

    function shuffle(array) {
        for (let i = array.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [array[i], array[j]] = [array[j], array[i]];
        }
        return array;
    }

    let currentIdx = 0;
    let scores = { a:0, b:0, c:0, d:0 };

    function startTest() {
        document.getElementById('start-page').classList.add('hidden');
        document.getElementById('quiz-page').classList.remove('hidden');
        showQuestion();
    }

    function showQuestion() {
        const qData = questions[currentIdx];
        document.getElementById('question-text').innerHTML = `<h2>${qData.q}</h2>`;
        const container = document.getElementById('options-container');
        container.innerHTML = '';
        
        const shuffledOptions = shuffle([...qData.options]);

        shuffledOptions.forEach(opt => {
            const btn = document.createElement('button');
            btn.className = 'option-btn';
            btn.innerText = opt.text;
            btn.onclick = () => nextQuestion(opt.type);
            container.appendChild(btn);
        });

        document.getElementById('progress-inner').style.width = `${(currentIdx / questions.length) * 100}%`;
    }

    function nextQuestion(type) {
        scores[type]++;
        currentIdx++;
        if (currentIdx < questions.length) {
            showQuestion();
        } else {
            showResult();
        }
    }

    function showResult() {
        document.getElementById('quiz-page').classList.add('hidden');
        document.getElementById('result-page').classList.remove('hidden');

        const maxScore = Math.max(scores.a, scores.b, scores.c, scores.d);
        let title = "";
        let desc = "";

        if (scores.b === maxScore) {
            title = "【육각형 데뷔 머신】";
            desc = "당신은 마스터들이 가장 신뢰하는 '육각형 연습생'입니다. 냉정하고, 프로페셔널하며, 흔들림이 없습니다. 누군가는 당신을 보고 독하다고 할지 모르지만, 실력으로 모든 논란을 잠재우는 스타일입니다. 데뷔는 이미 정해진 수순일지도? 팬들은 당신의 유능함에 열광할지만, 완벽주의가 스스로를 갉아먹지 않게 조심하세요";
        } else if (scores.a === maxScore) {
            title = "【눈물 가득 서사 맛집 】";
            desc = "당신은 이번 시즈 최고의 '눈물 치트키'입니다. 당신의 눈물 한 방울에 팬들의 투표권은 불타오릅니다. 다만, 팬들이 당신을 보며 같이 우느라 투표하는 것을 잊어버릴 수도? 멘탈 관리만 잘한다면 최고의 스타가 될 것입니다.";
        } else if (scores.c === maxScore) {
            title = "【실트 장악하는 트러블 메이커 】";
            desc = "당신은 방송의 재미를 책임지는 사람입니다. 솔직하고 거침없는 성격 덕분에 분량은 확실히 챙기지만, 악마의 편집에 희생될 위험도 큽니다. 호불호는 극명하게 갈리겠지만, 당신이 없는 이 프로그램은 무색무취 그 자체일 겁니다.";
        } else {
            title = "【간절함 제로 데뷔 조기퇴근 희망자】";
            desc = "서바이벌에서 도를 닦고 계시군요? 남들은 피 튀기게 경쟁할 때 혼자 해탈한 모습이 오히려 신선한 충격을 줍니다. '억지로 시켜서 하는 아이돌' 같은 매력에 빠진 팬들이 당신을 강제로 데뷔시킬 기세입니다.";
        }

        document.getElementById('result-title').innerText = title;
        document.getElementById('result-desc').innerText = desc;
    }
</script>

