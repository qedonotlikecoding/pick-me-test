            ]
        },
        {
            q: "10. 평가에 비해 점수가 너무 낮게 나왔다면?",
            options: [
                { text: "속상해서 의욕이 크게 꺾인다", type: "a" },
                { text: "점수 기준을 분석하며 부족한 점을 찾는다", type: "b" },
                { text: "불공평하다는 생각에 짜증 섞인 표정을 짓는다", type: "c" },
                { text: "점수가 전부는 아니라며 쿨하게 넘긴다", type: "d" }
            ]
        },
        {
            q: "11. 팀원이 뒤에서 내 욕을 하는 것을 들었다면?",
            options: [
                { text: "마음에 담아두고 계속 신경 쓰여 힘들어한다", type: "a" },
                { text: "상대방을 불러서 조용히 오해를 풀려고 시도한다", type: "b" },
                { text: "그 자리에서 똑같이 갚아주거나 표정으로 저격한다", type: "c" },
                { text: "누가 뭐라 하든 상관없다며 무관심으로 대응한다", type: "d" }
            ]
        },
        {
            q: "12. 하기 싫은 컨셉의 곡을 억지로 하게 되었다면?",
            options: [
                { text: "거부감이 커서 연습 내내 우울해한다", type: "a" },
                { text: "이왕 하는 거 새로운 도전이라 생각하고 몰입한다", type: "b" },
                { text: "연습하는 내내 툴툴거리거나 의욕 없는 티를 낸다", type: "c" },
                { text: "시키는 대로 기본만 하고 끝낸다", type: "d" }
            ]
        },
        {
            q: "13. 분량이 거의 없어 통편집 수준이라면?",
            options: [
                { text: "내가 매력이 없나 싶어 자책에 빠진다", type: "a" },
                { text: "분량을 따기 위해 킬링 파트를 더 연구한다", type: "b" },
                { text: "인위적으로라도 튀는 행동을 해서 카메라를 노린다", type: "c" },
                { text: "안 나오면 그만이지, 하는 마인드로 편하게 있는다", type: "d" }
            ]
        },
        {
            q: "14. 팬들이 소속사와 싸우며 실트 총공을 하고 있다면?",
            options: [
                { text: "나 때문에 팬들이 고생하는 것 같아 괴롭다", type: "a" },
                { text: "팬들이 걱정되지 않도록 더 좋은 모습을 보여주려 한다", type: "b" },
                { text: "화력이 좋은 걸 보고 내 영향력에 자부심을 느낀다", type: "c" },
                { text: "밖에서 무슨 일이 일어나든 내 연습에만 집중한다", type: "d" }
            ]
        },
        {
            q: "15. 공연 중 큰 실수를 해서 전국민적인 조롱을 받는다면?",
            options: [
                { text: "창피해서 한동안 남의 눈을 피하고 싶어진다", type: "a" },
                { text: "뭐가 문제였는지 수백 번 영상을 돌려보며 보완한다", type: "b" },
                { text: "악플러들이 너무하다고 생각하며 감정적으로 반응한다", type: "c" },
                { text: "누구나 실수할 수 있다며 금방 털어낸다", type: "d" }
            ]
        },
        {
            q: "16. 인기 최상위권 연습생에게 묻히게 된다면?",
            options: [
                { text: "비교당하는 기분에 자신감이 바닥을 친다", type: "a" },
                { text: "그 사람의 장점을 배우고 함께 윈윈할 방법을 찾는다", type: "b" },
                { text: "열등감을 느끼며 팀 분위기를 묘하게 만든다", type: "c" },
